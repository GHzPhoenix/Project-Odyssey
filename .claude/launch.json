{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["backend/index.js"],
      "port": 5001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-l", "3000", "--no-clipboard"],
      "port": 3000
    },
    {
      "name": "mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "--prefix", "mobile"],
      "port": 8081
    }
  ]
}
