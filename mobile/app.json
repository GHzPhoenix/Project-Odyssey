{
  "expo": {
    "name": "Travel Odyssey",
    "slug": "travel-odyssey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelodyssey.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Travel Odyssey to access your camera to upload a profile photo.",
        "NSLocationWhenInUseUsageDescription": "Allow Travel Odyssey to use your location to suggest nearby destinations.",
        "NSPhotoLibraryUsageDescription": "Allow Travel Odyssey to access your photo library to upload a profile photo."
      }
    },
    "android": {
      "package": "com.travelodyssey.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.travelodyssey.app",
          "enableGooglePay": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C3CE1",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9c7c09f0-9918-4006-9065-515ef4606ee9"
      }
    }
  }
}
